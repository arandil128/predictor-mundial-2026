# Copiá este archivo a .env y completá tus claves.
# Todas las claves son opcionales: si falta alguna, la app usa los datos
# que tenga disponibles (p. ej. ratings Elo del CSV) y lo avisa en la UI.

# The Odds API -> cuotas 1X2 (https://the-odds-api.com/ - free 500 req/mes)
ODDS_API_KEY=

# football-data.org -> fixtures/equipos (https://www.football-data.org/ - free con clave)
FOOTBALL_DATA_API_KEY=

# API-Football (api-sports.io) -> refuerzo de fixtures/estadísticas (free 100 req/día)
API_FOOTBALL_KEY=

# Parámetros del modelo (opcionales, tienen defaults razonables)
# Peso del mercado en la mezcla mercado<->modelo (0..1). 0.65 = 65% mercado.
MARKET_BLEND_WEIGHT=0.65
# Segundos de caché para respuestas de APIs externas.
CACHE_TTL_SECONDS=300

# --- WhatsApp: resumen diario de partidos (Evolution API) ---
# Si completás las 3 variables EVOLUTION_*, la app manda todos los días a la hora
# DAILY_SEND_TIME el listado de partidos del día a los teléfonos de data/phones.json.
EVOLUTION_API_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=
# Teléfonos destino. Opción A: archivo JSON (por defecto data/phones.json).
WHATSAPP_PHONES_FILE=
# Opción B (cómoda en deploy, tiene prioridad): el JSON {nombre: telefono} inline.
# Ej: WHATSAPP_PHONES={"Pablo":"5491112345678","Juan":"5492213334444"}
WHATSAPP_PHONES=
# Hora del envío diario (HH:MM) y zona horaria.
DAILY_SEND_TIME=07:30
DAILY_TIMEZONE=America/Argentina/Buenos_Aires
